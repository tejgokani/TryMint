{
  "name": "@trymint/agent",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "trymint": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {},
  "devDependencies": {}
}
