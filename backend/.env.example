# Server Configuration
NODE_ENV=development
TRYMINT_PORT=3000
TRYMINT_CORS_ORIGIN=http://localhost:5173
TRYMINT_LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Supported types: memory, redis, postgres, mongodb
DB_TYPE=memory
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trymint
DB_USER=trymint_user
DB_PASSWORD=your-database-password
# For MongoDB, use connection string format:
# DATABASE_URL=mongodb://localhost:27017/trymint
# For PostgreSQL, use connection string format:
# DATABASE_URL=postgresql://user:password@localhost:5432/trymint
# For Redis, use connection string format:
# DATABASE_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
JWT_EXPIRY=2h

# OAuth Configuration
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/v1/auth/github/callback

# Session Configuration
TRYMINT_SESSION_TTL_MS=7200000
TRYMINT_CREDENTIAL_TTL_MS=900000
TRYMINT_REFRESH_WINDOW_MS=300000
TRYMINT_MAX_SESSIONS_PER_USER=5
TRYMINT_SESSION_CLEANUP_INTERVAL_MS=60000

# WebSocket Configuration
WS_PORT=3001

# OpenAI (optional, for AI-generated TRYMINT Insight on demand)
# Set aiSummary=true when scanning to get a 60-80 word AI summary
OPENAI_API_KEY=
