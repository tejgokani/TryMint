# API Configuration
# Dev: leave empty to use Vite proxy (/v1 → localhost:3000)
# Prod (Vercel): REQUIRED - set to your Render backend URL, e.g. https://trymint-backend-xxxx.onrender.com/v1
# VITE_API_URL=https://trymint-backend-xxxx.onrender.com/v1

# OAuth Configuration (optional)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Session Configuration
VITE_SESSION_TIMEOUT=7200000

# Example dummy credentials for development:
# developer@trymint.io / password123
# admin@trymint.io / admin123
# test@trymint.io / test123
# Or use any email with password length >= 6 characters
